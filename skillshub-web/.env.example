# Local/Server shared env
PORT=3000

# Default to your existing flap env file
FLAP_ENV_FILE=/Users/klxhans/Downloads/flap-nfa-mint/.env

# Optional remote AI skill gateway for playground proxy mode
SKILLS_API_BASE=
SKILLS_API_PATH=/skills/run
SKILLS_API_KEY=
SKILLS_API_MODEL=gpt-4.1-mini

# Optional direct LLM config for `ai-quick-chat` (OpenRouter compatible)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional frontend base (leave empty for same-origin)
NEXT_PUBLIC_DEFAULT_API_BASE=

# GitHub repo base for skills deep-links in UI
# Example: https://github.com/your-org/bsc-skiller-brain
NEXT_PUBLIC_SKILLS_GITHUB_REPO=https://github.com/brief-onchain/skills-lab
